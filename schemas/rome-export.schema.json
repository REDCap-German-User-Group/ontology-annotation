{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/REDCap-German-User-Group/ontology-annotation/schemas/rome-export.schema.json",
	"title": "ROME Ontology Export Schema",
	"type": "object",
	"required": [
		"resourceType",
		"meta",
		"url",
		"title",
		"description",
		"dataElements"
	],
	"properties": {
		"resourceType": {
			"const": "ROME_Ontology_Annotations"
		},
		"meta": {
			"type": "object",
			"required": [
				"version",
				"created",
				"creator",
				"metadataState"
			],
			"properties": {
				"version": {
					"type": "string"
				},
				"created": {
					"type": "string",
					"format": "date-time"
				},
				"updated": {
					"type": "string",
					"format": "date-time"
				},
				"creator": {
					"type": "string"
				},
				"metadataState": {
					"type": "string",
					"enum": [
						"development",
						"production",
						"draft"
					]
				},
				"language": {
					"type": "string"
				},
				"profile": {
					"type": "array",
					"items": {
						"type": "string",
						"format": "uri"
					}
				}
			},
			"additionalProperties": true
		},
		"url": {
			"type": "string"
		},
		"title": {
			"type": "string"
		},
		"description": {
			"type": "string"
		},
		"dataElements": {
			"type": "array",
			"items": {
				"$ref": "#/$defs/DataElement"
			},
			"minItems": 1
		}
	},
	"additionalProperties": true,
	"$defs": {
		"Coding": {
			"type": "object",
			"required": [
				"system",
				"code"
			],
			"properties": {
				"system": {
					"type": "string",
					"format": "uri"
				},
				"code": {
					"type": "string"
				},
				"display": {
					"type": "string"
				}
			},
			"additionalProperties": true
		},
		"CodeableConcept": {
			"type": "object",
			"required": [
				"coding"
			],
			"properties": {
				"coding": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/Coding"
					},
					"minItems": 1
				},
				"text": {
					"type": "string"
				}
			},
			"additionalProperties": true
		},
		"ValueCodingMapEntry": {
			"type": "object",
			"required": [
				"text",
				"coding"
			],
			"properties": {
				"text": {
					"type": "string"
				},
				"coding": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/Coding"
					},
					"minItems": 1
				}
			},
			"additionalProperties": true
		},
		"DataElement": {
			"type": "object",
			"required": [
				"name",
				"text",
				"type"
			],
			"properties": {
				"name": {
					"type": "string"
				},
				"text": {
					"type": "string"
				},
				"type": {
					"type": "string",
					"enum": [
						"radio",
						"checkbox",
						"dropdown",
						"number",
						"string",
						"text",
						"time",
						"yesno",
						"truefalse",
						"slider",
						"file",
						"sql",
						"calc"
					]
				},
				"coding": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/Coding"
					},
					"minItems": 1
				},
				"format": {
					"type": "string"
				},
				"numericType": {
					"type": "string",
					"enum": [
						"integer",
						"decimal"
					]
				},
				"precision": {
					"oneOf": [
						{
							"type": "integer",
							"minimum": 0
						},
						{
							"type": "string",
							"enum": [
								"minutes",
								"seconds"
							]
						}
					]
				},
				"unit": {
					"$ref": "#/$defs/CodeableConcept"
				},
				"valueCodingMap": {
					"type": "object",
					"patternProperties": {
						"^.+$": {
							"$ref": "#/$defs/ValueCodingMapEntry"
						}
					},
					"additionalProperties": false
				}
			},
			"additionalProperties": true
		}
	}
}
