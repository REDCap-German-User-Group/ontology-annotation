{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/REDCap-German-User-Group/ontology-annotation/schemas/rome-annotation.schema.json",
	"title": "ROME Ontology Annotation Schema",
	"type": "object",
	"required": [
		"dataElement"
	],
	"properties": {
		"dataElement": {
			"type": "object",
			"required": [],
			"properties": {
				"coding": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/Coding"
					},
					"minItems": 1
				},
				"unit": {
					"type": "object",
					"required": [
						"coding"
					],
					"properties": {
						"coding": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/Coding"
							},
							"minItems": 1
						}
					},
					"additionalProperties": true
				},
				"valueCodingMap": {
					"type": "object",
					"patternProperties": {
						"^.+$": {
							"type": "object",
							"required": [
								"coding"
							],
							"properties": {
								"coding": {
									"type": "array",
									"items": {
										"$ref": "#/$defs/Coding"
									},
									"minItems": 1
								}
							},
							"additionalProperties": false
						}
					},
					"additionalProperties": false
				}
			},
			"additionalProperties": false
		}
	},
	"additionalProperties": false,
	"$defs": {
		"Coding": {
			"type": "object",
			"required": [
				"system",
				"code"
			],
			"properties": {
				"system": {
					"type": "string",
					"format": "uri"
				},
				"code": {
					"type": "string"
				},
				"display": {
					"type": "string"
				},
				"version": {
					"type": "string"
				}
			},
			"additionalProperties": true
		}
	}
}
